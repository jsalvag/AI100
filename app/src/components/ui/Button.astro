---
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  size?: 'sm' | 'md';
  type?: 'button' | 'submit';
  disabled?: boolean;
}

const { variant = 'secondary', href, size = 'md', type = 'button', disabled = false } = Astro.props;
const classes = `btn btn--${variant} btn--${size}`;
---

{
  href ? (
    <a href={href} class={classes}><slot /></a>
  ) : (
    <button type={type} class={classes} {disabled}><slot /></button>
  )
}
